{
	"name": "obsidian-web-search",
	"version": "0.1.0",
	"description": "Search selected text on the web via context menu or command palette",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "node --test tests/*.test.ts",
		"lint": "eslint .",
		"check": "pnpm test && pnpm lint && pnpm build"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "^0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "1.12.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
